# ─────────────────────────────────────────
# MetaRAG — .gitignore
# ─────────────────────────────────────────

# ── Python ────────────────────────────────
__pycache__/
*.py[cod]
*.pdb
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual Environment ───────────────────
.venv/
venv/
env/
ENV/
testsVenv_V1/
metarag_v1/

# ── Environment Variables ─────────────────
.env
.env.local
.env.*.local

# ── MetaRAG Generated Data ────────────────
# all local data — never commit
.metarag/

# old scattered paths — clean these up
metarag_db/
metarag_cache/
results.json

# ── Data Folder ───────────────────────────
# keep folder structure, ignore contents

# ── Model Files ───────────────────────────
*.pkl
*.joblib
*.pt
*.pth
*.bin
*.onnx

# ── Cache Files ───────────────────────────
*.npy
*.cache

# ── Logs ──────────────────────────────────
*.log
*.jsonl
logs/

# ── IDE ───────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── OS ────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Assets (keep) ─────────────────────────
# assets/ is committed — contains logo.svg
!assets/
!assets/**

queries.py

# Line to add — ignore OS temp files
*~
*.tmp
